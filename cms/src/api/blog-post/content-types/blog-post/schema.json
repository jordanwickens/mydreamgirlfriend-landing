{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "Blog articles for the landing site"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    },
    "keywords": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "AI Girlfriend Guides",
        "Comparisons & Alternatives",
        "AI Companion Tips"
      ],
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "datePublished": {
      "type": "date",
      "required": true
    },
    "dateModified": {
      "type": "date"
    },
    "body": {
      "type": "blocks"
    },
    "faqs": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq-item"
    },
    "relatedSlugs": {
      "type": "json"
    },
    "ctaHeading": {
      "type": "string"
    },
    "ctaText": {
      "type": "text"
    },
    "ctaButtonText": {
      "type": "string"
    },
    "ctaButtonUrl": {
      "type": "string"
    }
  }
}
